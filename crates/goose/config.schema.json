    },
    "ExtensionEntry": {
      "description": "Represents the different types of MCP extensions that can be added to the manager",
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "oneOf": [
        {
          "description": "SSE transport is no longer supported - kept only for config file compatibility",
          "type": "object",
          "properties": {
            "description": {
              "type": "string",
              "default": ""
            },
            "name": {
              "type": "string",
              "default": ""
            },
            "type": {
              "type": "string",
              "const": "sse"
            },
            "uri": {
              "type": [
                "string",
                "null"
              ],
              "default": null
            }
          },
          "required": [
            "type"
          ]
        },
        {
          "description": "Standard I/O client with command and arguments",
          "type": "object",
          "properties": {
            "args": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "available_tools": {
              "type": "array",
              "default": [],
              "items": {
                "type": "string"
              }
            },
            "bundled": {
              "type": [
                "boolean",
                "null"
              ],
              "default": null
            },
            "cmd": {
              "type": "string"
            },
            "description": {
              "type": "string",
              "default": ""
            },
            "env_keys": {
              "type": "array",
              "default": [],
              "items": {
                "type": "string"
              }
            },
            "envs": {
              "$ref": "#/$defs/Envs",
              "default": {}
            },
            "name": {
              "description": "The name used to identify this extension",
              "type": "string"
            },
            "timeout": {
              "type": [
                "integer",
                "null"
              ],
              "format": "uint64",
              "minimum": 0
            },
            "type": {
              "type": "string",
              "const": "stdio"
            }
          },
          "required": [
            "type",
            "name",
            "cmd",
            "args"
          ]
        },
        {
          "description": "Built-in extension that is part of the bundled goose MCP server",
          "type": "object",
          "properties": {
            "available_tools": {
              "type": "array",
              "default": [],
              "items": {
                "type": "string"
              }
            },
            "bundled": {
              "type": [
                "boolean",
                "null"
              ],
              "default": null
            },
            "description": {
              "type": "string",
              "default": ""
            },
            "display_name": {
              "type": [
                "string",
                "null"
              ]
            },
            "name": {
              "description": "The name used to identify this extension",
              "type": "string"
            },
            "timeout": {
              "type": [
                "integer",
                "null"
              ],
              "format": "uint64",
              "minimum": 0
            },
            "type": {
              "type": "string",
              "const": "builtin"
            }
          },
          "required": [
            "type",
            "name"
          ]
        },
        {
          "description": "Platform extensions that have direct access to the agent etc and run in the agent process",
          "type": "object",
          "properties": {
            "available_tools": {
              "type": "array",
              "default": [],
