              "const": "platform"
            }
          },
          "required": [
            "type",
            "name"
          ]
        },
        {
          "description": "Streamable HTTP client with a URI endpoint using MCP Streamable HTTP specification",
          "type": "object",
          "properties": {
            "available_tools": {
              "type": "array",
              "default": [],
              "items": {
                "type": "string"
              }
            },
            "bundled": {
              "type": [
                "boolean",
                "null"
              ],
              "default": null
            },
            "description": {
              "type": "string",
              "default": ""
            },
            "env_keys": {
              "type": "array",
              "default": [],
              "items": {
                "type": "string"
              }
            },
            "envs": {
              "$ref": "#/$defs/Envs",
              "default": {}
            },
